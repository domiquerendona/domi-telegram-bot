# ============================================================
# CONFIGURACIÓN DE ENTORNO - DESARROLLO (LOCAL)
# ============================================================
# Copia este archivo a .env y completa con tus valores

# Ambiente: LOCAL para desarrollo, PROD para producción (Railway)
ENV=LOCAL

# Token del bot de Telegram (IMPORTANTE: usar token diferente a PROD)
BOT_TOKEN=your_dev_bot_token_here

# ID del administrador de plataforma
ADMIN_USER_ID=your_telegram_user_id

# IDs de grupos
COURIER_CHAT_ID=0
RESTAURANT_CHAT_ID=0

# Ruta de la base de datos
DB_PATH=domiquerendona.db

# Ruta del archivo de persistencia del bot (user_data, conversation states)
# En Railway con volumen persistente: /data/bot_persistence.pkl
PERSISTENCE_PATH=bot_persistence.pkl

# ============================================================
# IMPORTANTE: SEPARACIÓN DEV/PROD
# ============================================================
#
# Para evitar conflicto "terminated by other getUpdates request":
#
# 1. DEV (PC local):
#    - ENV=LOCAL
#    - BOT_TOKEN=<token de bot de desarrollo>
#    - Crea un bot separado con @BotFather para desarrollo
#
# 2. PROD (Railway):
#    - ENV=PROD (o sin definir, usa PROD por defecto)
#    - BOT_TOKEN=<token de bot de producción>
#    - Configura variables en Railway, NO uses .env
#
# NUNCA uses el mismo BOT_TOKEN en DEV y PROD simultáneamente
#

# Credenciales del panel web administrativo
WEB_ADMIN_USER=admin
WEB_ADMIN_PASSWORD=changeme
WEB_SECRET_KEY=cambia-esta-clave-secreta-en-produccion

# URL pública del panel web Angular (Railway).
# Si se define, el bot muestra un botón directo al panel para admins y repartidores.
# Ejemplo PROD: https://angular-production-44c8.up.railway.app
# Ejemplo DEV:  https://angular-staging-xxxx.up.railway.app
WEB_PANEL_URL=  http://localhost:4200/
